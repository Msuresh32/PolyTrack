# Discord channel webhook: Server Settings -> Integrations -> Webhooks -> New Webhook -> Copy URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/XXXX/YYYY

# Wallets to track: label=address, comma separated
WALLETS=@flipadelphia=0x448861155279dbf833d041b963e3ac854599e319,@beachboy4=0xc2e7800b5af46e6093872b177b7a5e7f0563be51

POLL_SECONDS=10
MIN_ALERT_USD=200
SPORTS_ONLY=true

# Your own bankroll and per-unit size for tail-stake suggestions.
# At conviction=100 the suggested tail = MY_BASE_UNIT; scales linearly down.
MY_BANKROLL=10000
MY_BASE_UNIT=100

# Optional dashboard expansion from ingest_sharp_wallets.py
SHARP_WALLETS_FILE=sharp_wallets_selected.json
POLYMARKET_ANALYTICS_STATS=true
POLYMARKET_ANALYTICS_API=https://legacy.polymarketanalytics.com/api/traders-tag-performance
MIN_AMERICAN_ODDS=-250
MAX_AMERICAN_ODDS=250
